# Copy to a private file on the host, for example:
#   $HOME/.proxywar/proxywar-beta.env
#
# Do not commit the real file. It contains the invite code and deployment URL.

NODE_ENV=production
GAME_ENV=dev

# Real Cloudflare Tunnel hostname. Must be HTTPS.
PROXYWAR_PUBLIC_URL=https://beta.your-domain.example

# Invite gate.
PROXYWAR_BETA_ENABLED=true
PROXYWAR_BETA_CODE=replace-with-private-invite-code
PROXYWAR_BETA_LABEL=Private beta
PROXYWAR_BETA_COOKIE_SECURE=true

# Strict external-agent policy for remote testers.
PROXYWAR_ALLOW_PRIVATE_AGENT_ENDPOINTS=false

# Keep the first private beta boringly reliable: one running job plus one queued job.
PROXYWAR_MAX_QUEUED_JOBS=1

# House agents must be LLM-backed for tester matches.
PROXYWAR_HOUSE_AGENT_BRAIN=planner-codex-cli
AI_LEAGUE_LLM_PROVIDER=codex-cli
AI_LEAGUE_REQUIRE_EXTERNAL_BRAIN_SUCCESS=true
AI_LEAGUE_CODEX_MODEL=gpt-5.4
AI_LEAGUE_CODEX_REASONING_EFFORT=medium
AI_LEAGUE_CODEX_TIMEOUT_MS=180000

# If launchd cannot find Codex, set the absolute command path.
AI_LEAGUE_CODEX_COMMAND=/Users/YOUR_USER/.local/bin/codex

# Hub and renderer stay private behind Cloudflare Tunnel.
AI_LEAGUE_DEMO_HOST=127.0.0.1
AI_LEAGUE_DEMO_PORT=8787
AI_LEAGUE_RENDERER_HOST=127.0.0.1
AI_LEAGUE_RENDERER_PORT=9000
AI_LEAGUE_RENDERER_BASE_URL=http://127.0.0.1:9000

# Conservative public-beta rate limits per minute.
PROXYWAR_RATE_LIMIT_WINDOW_MS=60000
PROXYWAR_RATE_LIMIT_BETA_LOGIN=20
PROXYWAR_RATE_LIMIT_JOBS=4
PROXYWAR_RATE_LIMIT_NATIONS=20
PROXYWAR_RATE_LIMIT_EXTERNAL_CHECK=30
PROXYWAR_RATE_LIMIT_FEEDBACK=20

# Backups. Keep this outside the repo if possible.
PROXYWAR_BACKUP_DIR=/Users/YOUR_USER/ProxyWarBackups

# Production saved-agent roster. Keep this outside the repo so old local QA
# agents with localhost endpoints do not leak into the hosted beta.
PROXYWAR_NATIONS_DIR=/Users/YOUR_USER/.proxywar/nations

# Give the renderer enough memory on a small macOS host.
NODE_OPTIONS=--max-old-space-size=8192
