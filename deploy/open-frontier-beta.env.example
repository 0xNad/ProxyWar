# Copy this file to a private environment file on the host.
# Do not commit the real file with invite codes, tokens, or domain-specific secrets.

NODE_ENV=production
GAME_ENV=dev

# Public beta URL. Must be HTTPS for remote testers.
OPEN_FRONTIER_PUBLIC_URL=https://beta.your-domain.example

# Invite gate. Use a private value with at least 8 characters.
OPEN_FRONTIER_BETA_ENABLED=true
OPEN_FRONTIER_BETA_CODE=replace-with-private-invite-code
OPEN_FRONTIER_BETA_LABEL=Private beta

# Hosted mode should not allow localhost/LAN/private agent endpoints.
OPEN_FRONTIER_ALLOW_PRIVATE_AGENT_ENDPOINTS=false

# Keep queue small for first testers.
OPEN_FRONTIER_MAX_QUEUED_JOBS=1

# House nations used to fill tester matches. In the private beta these must be
# LLM-backed; Codex CLI is the current provider.
OPEN_FRONTIER_HOUSE_AGENT_BRAIN=planner-codex-cli
AI_LEAGUE_LLM_PROVIDER=codex-cli
AI_LEAGUE_REQUIRE_EXTERNAL_BRAIN_SUCCESS=true
AI_LEAGUE_CODEX_MODEL=gpt-5.4
AI_LEAGUE_CODEX_REASONING_EFFORT=medium
AI_LEAGUE_CODEX_TIMEOUT_MS=180000

# Rate limits per window.
OPEN_FRONTIER_RATE_LIMIT_WINDOW_MS=60000
OPEN_FRONTIER_RATE_LIMIT_BETA_LOGIN=20
OPEN_FRONTIER_RATE_LIMIT_JOBS=8
OPEN_FRONTIER_RATE_LIMIT_NATIONS=24
OPEN_FRONTIER_RATE_LIMIT_EXTERNAL_CHECK=40
OPEN_FRONTIER_RATE_LIMIT_FEEDBACK=20

# Hub and renderer listen only on localhost behind the reverse proxy.
AI_LEAGUE_DEMO_HOST=127.0.0.1
AI_LEAGUE_DEMO_PORT=8787
AI_LEAGUE_RENDERER_HOST=127.0.0.1
AI_LEAGUE_RENDERER_PORT=9000
AI_LEAGUE_RENDERER_BASE_URL=http://127.0.0.1:9000

# Give Vite enough memory for the replay renderer.
NODE_OPTIONS=--max-old-space-size=8192

# Put backups somewhere durable on the hosted machine.
OPEN_FRONTIER_BACKUP_DIR=/var/backups/open-frontier

# Production saved-agent roster. Keep this outside the repo so old local QA
# agents with localhost endpoints do not leak into hosted beta.
OPEN_FRONTIER_NATIONS_DIR=/var/lib/open-frontier/nations
