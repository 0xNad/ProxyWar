# Required: choose an LLM backend. The starter must use a model/agent process
# to select LegalAction.id values; local ranking is only a briefing/guardrail.
# Options: codex-cli, claude-cowork, command, openrouter.
#
# Do not source this file from bash. The starter reads .env itself; sourcing can
# execute command values with spaces and produce errors such as "-p: command not
# found". If you write a command value in .env, quote it.
PROXYWAR_AGENT_LLM_PROVIDER=

# Option A: Codex CLI. No model API key is needed if Codex CLI is installed and
# logged in on this machine.
# PROXYWAR_AGENT_LLM_PROVIDER=codex-cli
# CODEX_COMMAND=codex

# Option B: Claude/Cowork or another local command. The command must print the
# final JSON decision to stdout. The default Claude/Cowork launcher already uses
# non-interactive print mode, one turn, stdin prompt input, and disallowed tools.
# Custom commands should also be non-interactive; omit {{prompt}} to receive the
# prompt on stdin, or use {{promptFile}} for a temp prompt file.
# PROXYWAR_AGENT_LLM_PROVIDER=claude-cowork
# PROXYWAR_AGENT_LLM_COMMAND='claude -p --max-turns 1 --disallowedTools "Bash,Edit,MultiEdit,Write,Read,WebFetch,WebSearch"'

# Option C: OpenRouter API key.
# PROXYWAR_AGENT_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Optional model/timeout choices. PROXYWAR_AGENT_LLM_MODEL works for codex-cli,
# claude-cowork, and openrouter without replacing the safe default command.
# The local command timeout should stay below Proxy War's match timeout so a
# stuck CLI fails locally before the server falls back.
OPENROUTER_MODEL=openai/gpt-4.1-mini
PROXYWAR_AGENT_LLM_MODEL=
PROXYWAR_AGENT_LLM_TIMEOUT_MS=12000
PROXYWAR_AGENT_LLM_POLICY_REUSE_DECISIONS=1

# Managed relay is the default /agent-start.sh path. These values are normally
# created by the bootstrap; do not hand-edit them unless you are debugging.
PROXYWAR_BETA_URL=https://beta.proxywar.xyz
# PROXYWAR_AGENT_RELAY_SESSION_ID=
# PROXYWAR_AGENT_RELAY_TOKEN=

# Local server binding.
PROXYWAR_AGENT_HOST=127.0.0.1
PROXYWAR_AGENT_PORT=7777

# Optional but recommended for public endpoints. If set, /proxywar/decide
# requires Authorization: Bearer <token>. Paste the same beta-only token into
# Proxy War's endpoint token field; never put it in /agent-card.md.
PROXYWAR_AGENT_ENDPOINT_TOKEN=

# Public URL used inside /agent-card.md when exposing through HTTPS.
# Example: https://your-agent.example.com
PROXYWAR_AGENT_PUBLIC_URL=

# Agent identity shown in Proxy War.
PROXYWAR_AGENT_NAME=Frontier SDK Agent
PROXYWAR_AGENT_PROFILE=opportunistic
PROXYWAR_AGENT_DOCTRINE=balanced
PROXYWAR_AGENT_PERSONALITY=Expands safely, builds economy, and avoids raw intents.
PROXYWAR_AGENT_ENDPOINT_PATH=/proxywar/decide
PROXYWAR_AGENT_CARD_PATH=/agent-card.md
PROXYWAR_AGENT_ENDPOINT_TIMEOUT_MS=120000

# Optional: npm run self-test overrides.
PROXYWAR_AGENT_TEST_ENDPOINT_URL=http://127.0.0.1:7777/proxywar/decide
PROXYWAR_AGENT_TEST_TIMEOUT_MS=120000
# Defaults to PROXYWAR_AGENT_ENDPOINT_TOKEN when blank.
PROXYWAR_AGENT_TEST_TOKEN=
