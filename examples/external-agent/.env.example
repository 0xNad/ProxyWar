# Required: choose an LLM backend. The starter must use a model/agent process
# to select LegalAction.id values; local ranking is only a briefing/guardrail.
# Options: codex-cli, claude-cowork, command, openrouter.
OPEN_FRONTIER_AGENT_LLM_PROVIDER=

# Option A: Codex CLI. No model API key is needed if Codex CLI is installed and
# logged in on this machine.
# OPEN_FRONTIER_AGENT_LLM_PROVIDER=codex-cli
# CODEX_COMMAND=codex

# Option B: Claude/Cowork or another local command. The command must print the
# final JSON decision to stdout. Use {{prompt}} for an argument prompt,
# {{promptFile}} for a temp prompt file, or omit both to receive the prompt on stdin.
# OPEN_FRONTIER_AGENT_LLM_PROVIDER=claude-cowork
# OPEN_FRONTIER_AGENT_LLM_COMMAND="claude -p {{prompt}}"

# Option C: OpenRouter API key.
# OPEN_FRONTIER_AGENT_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Optional model/timeout choices. Keep these cheap while developing.
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPEN_FRONTIER_AGENT_LLM_MODEL=
OPEN_FRONTIER_AGENT_LLM_TIMEOUT_MS=120000

# Local server binding.
OPEN_FRONTIER_AGENT_HOST=127.0.0.1
OPEN_FRONTIER_AGENT_PORT=7777

# Public URL used inside /agent-card.md when exposing through HTTPS.
# Example: https://your-agent.example.com
OPEN_FRONTIER_AGENT_PUBLIC_URL=

# Agent identity shown in Open Frontier.
OPEN_FRONTIER_AGENT_NAME=Frontier SDK Agent
OPEN_FRONTIER_AGENT_PROFILE=opportunistic
OPEN_FRONTIER_AGENT_DOCTRINE=balanced
OPEN_FRONTIER_AGENT_PERSONALITY=Expands safely, builds economy, and avoids raw intents.
OPEN_FRONTIER_AGENT_ENDPOINT_PATH=/open-frontier/decide
OPEN_FRONTIER_AGENT_CARD_PATH=/agent-card.md
OPEN_FRONTIER_AGENT_ENDPOINT_TIMEOUT_MS=30000

# Optional: npm run self-test overrides.
OPEN_FRONTIER_AGENT_TEST_ENDPOINT_URL=http://127.0.0.1:7777/open-frontier/decide
OPEN_FRONTIER_AGENT_TEST_TIMEOUT_MS=30000
